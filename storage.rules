rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Images: retreats, spaces, services, users
    // Path pattern: {collection}/{entityId}/gallery/{fileName}
    match /retreats/{retreatId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /spaces/{spaceId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /services/{serviceId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
